NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Filled in TASK-002 (Supabase). Uses the new Supabase API key format:
# - Publishable key starts with `sb_publishable_` and is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Dev-only escape hatch for /admin/* routes. Set to "true" locally to bypass the
# users.role='admin' check before you seed your first admin user. Ignored in
# production (NODE_ENV=production). Never commit a .env.local with this enabled.
ALLOW_ADMIN_WITHOUT_ROLE=false

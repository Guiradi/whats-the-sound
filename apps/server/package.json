{
  "name": "@wts/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:local": "node --env-file=.env.local dist/index.js",
    "lint": "biome check src",
    "type-check": "tsc --noEmit",
    "smoke:db": "tsx --env-file=.env.local scripts/smoke-db.ts",
    "smoke:sprint3": "tsx scripts/smoke-sprint3.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.47.10",
    "@wts/shared": "workspace:*",
    "fastify": "^5.2.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

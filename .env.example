# ============================================================
# Docker environment template — copy to .env and fill in values
#   cp .env.example .env
#
# NOTE: NEXT_PUBLIC_* vars are baked into the web image at build
# time. Run `docker compose up --build` after changing them.
# ============================================================


# ============================================================
# Frontend — apps/web
# ============================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Supabase — Project Settings → API
# Publishable key starts with sb_publishable_ (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Admin bypass — set true locally before seeding your first admin user
# Ignored in production (NODE_ENV=production). Never commit as true.
ALLOW_ADMIN_WITHOUT_ROLE=false


# ============================================================
# Backend — apps/server
# ============================================================

PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# Supabase — secret key stays server-side only, never expose to browser
# Secret key starts with sb_secret_
# Anon key is used to build per-request user-scoped clients on the server so
# RLS applies behind the manual filters (defense-in-depth). Same value as
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY above.
# DATABASE_URL: Session Pooler connection string (port 5432)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Daily Sound seed — any random string, 8+ characters
# DAILY_SEED=changeme123
